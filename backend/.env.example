APP_NAME=AI Job Search System
DATABASE_URL=postgresql+psycopg2://jobsearch:jobsearch@localhost:5432/jobsearch
REDIS_URL=redis://localhost:6379/0
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Required for production AI ranking and explanation generation.
# The app still has deterministic local fallbacks for offline development.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Optional real-data providers.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
